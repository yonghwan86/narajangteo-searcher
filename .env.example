# 공공데이터포털 인증키 (필수)
# 발급: https://www.data.go.kr/data/15129394/openapi.do → 활용신청 후 발급되는 "일반 인증키"
# 아래에 발급받은 인증키를 입력하세요.
NARAJANGTEO_SERVICE_KEY=여기에_발급받은_인증키_입력

# 인증키 인코딩 여부 (선택, 기본값: 자동 판별)
# 공공데이터포털은 "일반 인증키(Encoding)"과 "일반 인증키(Decoding)" 두 가지를 제공합니다.
#  - Encoding 키(% 포함, 예: a%2Bb...)를 넣었다면: true
#  - Decoding 키(원본, % 없음)를 넣었다면: false
# 미지정 시 키에 '%'가 포함되어 있으면 Encoding으로 자동 판별합니다.
# NARAJANGTEO_SERVICE_KEY_IS_ENCODED=true

# API 호출 프로토콜 (선택, 기본값: https)
# G2B_API_PROTOCOL=https
